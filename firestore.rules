rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    match /schemes/{schemeId} {
      allow read: if true;
      allow write: if true;
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow write: if true;
    }

    match /scholarships/{scholarshipId} {
      allow read: if true;
      allow write: if true;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if true;
    }

    match /suggestions/{suggestionId} {
      allow read, write: if true;
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
